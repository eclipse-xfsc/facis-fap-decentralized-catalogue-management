[
    {
        "id": "cc01000000000000",
        "type": "tab",
        "label": "DCM-CatalogueRegistry",
        "disabled": false,
        "info": "Backend flows for Catalogue Registry.\n\nMongoDB collection: cr_catalogues\n\nOperations:\n  - registerRemoteCatalog (insertOne)\n  - getCatalogRegistry (find all)\n  - updateRemoteCatalog (updateOne with patch)\n  - deleteRemoteCatalog (deleteOne)\n  - uploadCatalogJson (bulk insertMany)\n\nAll responses are sent back to the Dashboard via link-out → dashboard-linkin (1320340df737c22e).",
        "env": []
    },

    {
        "id": "cc01000000000001",
        "type": "comment",
        "z": "cc01000000000000",
        "name": "══ Catalogue Registry Backend ══",
        "info": "Handles all Catalogue Registry operations.\nResponses go back to Dashboard uibuilder via link-out → dashboard-linkin.",
        "x": 240,
        "y": 40,
        "wires": []
    },

