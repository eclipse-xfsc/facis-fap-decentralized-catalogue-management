    {
        "id": "cc01000000000020",
        "type": "function",
        "z": "cc01000000000000",
        "name": "Register Remote Catalog",
        "func": "const chars = 'abcdefghijklmnopqrstuvwxyz0123456789';\nlet randomPart = '';\nfor (let i = 0; i < 12; i++) {\n  randomPart += chars[Math.floor(Math.random() * chars.length)];\n}\nconst id = Date.now().toString(36) + randomPart;\n\nmsg.uniqueId = id;\nmsg.operation = \"insertOne\";\nmsg.collection = \"cr_catalogues\";\nmsg.payload = {\n    catalog: msg.data,\n    uniqueId: id\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 620,
        "y": 100,
        "wires": [["cc01000000000021"]]
    },
    {
        "id": "cc01000000000021",
        "type": "mongodb4",
        "z": "cc01000000000000",
        "clientNode": "ad5bea80de70463c",
        "mode": "collection",
        "collection": "",
        "operation": "",
        "output": "toArray",
        "maxTimeMS": "0",
        "handleDocId": false,
        "name": "",
        "x": 880,
        "y": 100,
        "wires": [["cc01000000000022"]]
    },
    {
        "id": "cc01000000000022",
        "type": "function",
        "z": "cc01000000000000",
        "name": "response",
        "func": "msg.response = {\n    action: \"registerRemoteCatalog\",\n    status: \"success\",\n    uniqueId: msg.uniqueId\n};\ndelete msg.payload;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1100,
        "y": 100,
        "wires": [["cc010000000000f0"]]
    },

    {
        "id": "cc01000000000030",
        "type": "function",
        "z": "cc01000000000000",
        "name": "Get Catalog Registry",
        "func": "msg.operation = \"find\";\nmsg.collection = \"cr_catalogues\";\nmsg.payload = [\n    {},\n    { projection: { catalog: 1, uniqueId: 1, _id: 0 } }\n];\nreturn msg;",
