        "rules": [
            { "t": "eq", "v": "registerRemoteCatalog", "vt": "str" },
            { "t": "eq", "v": "getCatalogRegistry", "vt": "str" },
            { "t": "eq", "v": "updateRemoteCatalog", "vt": "str" },
            { "t": "eq", "v": "deleteRemoteCatalog", "vt": "str" },
